<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.unipath.ui.UC10.MeetingCalendarScreen" style="-fx-background-color: #f8f9fa;">
    <children>
        <Label text="Ημερολόγιο Συναντήσεων Καθηγητή" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2B3A42;"/>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <children>
                <ComboBox fx:id="dayComboBox" promptText="Ημέρα"/>
                <TextField fx:id="startTimeField" promptText="Έναρξη (e.g. 10:00)" prefWidth="120.0"/>
                <TextField fx:id="endTimeField" promptText="Λήξη (e.g. 11:00)" prefWidth="120.0"/>
                <Button text="Προσθήκη Slot" onAction="#onAddSlot" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
            </children>
        </HBox>

        <Label text="Επιλεγμένα Ώρες Συναντήσεων:"/>
        <ListView fx:id="slotListView" prefHeight="150.0"/>

        <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-weight: bold;"/>

        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <children>
                <Button text="Δημοσίευση Αγγελίας Διπλωματικής" onAction="#onPublishThesisClick"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20;"/>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
</VBox>