<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.unipath.ui.UC11.ThesisBoardScreen"
      spacing="20"
      prefWidth="1000" prefHeight="650"
      style="-fx-background-color: #f4f7f9;">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🎓 Πινακίδα Διαθέσιμων Διπλωματικών"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    </HBox>

    <Separator />

    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Αναζήτηση θέματος ή καθηγητή..."
                   prefWidth="400" style="-fx-background-radius: 15;"/>
        <ComboBox fx:id="categoryFilter" promptText="Κατηγορία" prefWidth="200" />
    </HBox>

    <VBox VBox.vgrow="ALWAYS" spacing="10">
        <Label text="Επιλέξτε μια διπλωματική για να δείτε λεπτομέρειες ή να κλείσετε ραντεβού:"
               style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

        <TableView fx:id="thesisTableView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;">
            <columns>
                <TableColumn fx:id="colTitle" text="Τίτλος Θέματος" prefWidth="350" />
                <TableColumn fx:id="colProfessor" text="Επιβλέπων" prefWidth="200" />
                <TableColumn fx:id="colCategory" text="Τομέας" prefWidth="150" />
                <TableColumn fx:id="colStatus" text="Κατάσταση" prefWidth="120" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="20">
        <Button fx:id="viewDetailsButton" text="👁️ Προβολή Λεπτομερειών"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 5; -fx-cursor: hand;"/>

        <Button fx:id="bookAppointmentButton" text="📅 Κλείσιμο Ραντεβού"
                onAction="#handleBookAppointment"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 5; -fx-cursor: hand;"/>
    </HBox>

</VBox>