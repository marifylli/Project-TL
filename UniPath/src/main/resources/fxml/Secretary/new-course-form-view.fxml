<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1000" prefHeight="650"
            stylesheets="@../../css/styles.css">

    <top>
        <HBox styleClass="prof-header" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <Label text="📚 Προσθήκη Νέου Μαθήματος" styleClass="prof-header-name"/>
        </HBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="0">
            <padding><Insets top="32" right="48" bottom="32" left="48"/></padding>

            <VBox spacing="20" maxWidth="560" HBox.hgrow="ALWAYS">
                <Label text="Στοιχεία Νέου Μαθήματος"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>

                <!-- Κωδικός Μαθήματος -->
                <VBox spacing="6">
                    <Label text="Κωδικός Μαθήματος *" styleClass="prof-section-title"/>
                    <TextField fx:id="courseIdField"
                               promptText="π.χ. CS101"
                               styleClass="prof-text-field"/>
                </VBox>

                <!-- Τίτλος -->
                <VBox spacing="6">
                    <Label text="Τίτλος Μαθήματος *" styleClass="prof-section-title"/>
                    <TextField fx:id="titleField"
                               promptText="π.χ. Εισαγωγή στην Πληροφορική"
                               styleClass="prof-text-field"/>
                </VBox>

                <!-- Περιγραφή -->
                <VBox spacing="6">
                    <Label text="Περιγραφή" styleClass="prof-section-title"/>
                    <TextArea fx:id="descriptionField"
                              promptText="Σύντομη περιγραφή του μαθήματος..."
                              prefRowCount="3"
                              wrapText="true"
                              styleClass="prof-text-field"/>
                </VBox>

                <!-- ECTS & Εξάμηνο -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="ECTS *" styleClass="prof-section-title"/>
                        <TextField fx:id="ectsField"
                                   promptText="π.χ. 5"
                                   styleClass="prof-text-field"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Εξάμηνο *" styleClass="prof-section-title"/>
                        <TextField fx:id="semesterField"
                                   promptText="π.χ. 3"
                                   styleClass="prof-text-field"/>
                    </VBox>
                </HBox>

                <!-- Error Label -->
                <Label fx:id="errorLabel"
                       text=""
                       visible="false"
                       wrapText="true"
                       style="-fx-text-fill: #e53e3e; -fx-font-size: 13px;"/>

                <!-- Submit Button -->
                <Button fx:id="btnSubmit"
                        text="Επόμενο: Επιλογή Διδάσκοντα →"
                        styleClass="prof-action-btn-primary"
                        onAction="#onSubmit"
                        maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </center>

</BorderPane>
