<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.unipath.ui.common.SecretaryMainScreen"
            prefWidth="1000" prefHeight="650"
            stylesheets="@../../css/styles.css">

    <top>
        <HBox styleClass="prof-header" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <Label fx:id="secretaryNameLabel" text="Γραμματεία" styleClass="prof-header-name"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="24">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label text="Διαθέσιμες Λειτουργίες" styleClass="prof-section-title"/>
                <Label text="Επιλέξτε μια λειτουργία από το μενού για να συνεχίσετε."
                       style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
            </VBox>

            <VBox spacing="20" minWidth="250" alignment="TOP_CENTER">
                <padding><Insets top="40"/></padding>

                <Button fx:id="addCourseButton" text="➕ Προσθήκη Μαθήματος"
                        styleClass="prof-action-btn-primary" onAction="#clickAddCourse"
                        maxWidth="Infinity" wrapText="true"/>

                <Button fx:id="editCourseButton" text="✏️ Επεξεργασία Μαθήματος"
                        styleClass="prof-action-btn-primary" onAction="#clickEditCourse"
                        maxWidth="Infinity" wrapText="true"/>

                <Button fx:id="statsButton" text="📊 Στατιστικά &amp; Αναφορές"
                        styleClass="prof-action-btn-primary" onAction="#clickStats"
                        maxWidth="Infinity" wrapText="true"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>

