<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1000" prefHeight="650"
            stylesheets="@../../css/styles.css">

    <top>
        <HBox styleClass="prof-header" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <Label text="📈 Αποτελέσματα Στατιστικής Ανάλυσης" styleClass="prof-header-name"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="24">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <!-- Αριστερά: Κατανομές -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">

                <Label text="Κατανομή ανά Κατεύθυνση" styleClass="prof-section-title"/>
                <Label fx:id="perDirectionLabel" text="-" wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>

                <Separator/>

                <Label text="Κατανομή ανά Ακαδημαϊκό Έτος" styleClass="prof-section-title"/>
                <Label fx:id="perYearLabel" text="-" wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #4a5568;"/>
            </VBox>

            <!-- Δεξιά: Σύνοψη & Actions -->
            <VBox spacing="20" minWidth="280" alignment="TOP_CENTER"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

                <Label text="Σύνοψη" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>

                <VBox spacing="8">
                    <Label text="Συνολικά Πλάνα" styleClass="prof-section-title"/>
                    <Label fx:id="totalPlansLabel" text="0"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3182ce;"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Μέσος Όρος ECTS" styleClass="prof-section-title"/>
                    <Label fx:id="avgEctsLabel" text="0.0"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #38a169;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Εξαγωγή Εγγράφου →"
                        styleClass="prof-action-btn-primary"
                        onAction="#onExportReport"
                        maxWidth="Infinity"/>

                <Button text="← Πίσω στα Φίλτρα"
                        onAction="#onBack"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568;
                               -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 20 10 20;
                               -fx-background-radius: 6;"
                        maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </center>

</BorderPane>
