<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.unipath.ui.UC8.AvailableOffersScreen"
      alignment="CENTER"
      spacing="20"
      styleClass="root-pane"
      stylesheets="@../../css/styles.css">

    <VBox alignment="CENTER" spacing="10" styleClass="login-card" maxWidth="550" style="-fx-padding: 30;">
        <Label text="UniPath - Διαθέσιμες Προσφορές Μεντόρων" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1ea1e2;"/>
        <Label fx:id="courseTitleLabel" text="Μάθημα: " style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        <Region minHeight="10"/>

        <VBox alignment="CENTER_LEFT" spacing="5" maxWidth="Infinity">
            <Label text="Επιλέξτε τον Mentor που σας ενδιαφέρει:" style="-fx-font-weight: bold;"/>
            <ListView fx:id="offersListView" prefHeight="220" maxWidth="Infinity"/>
        </VBox>

        <Region minHeight="20"/>

        <HBox spacing="15" alignment="CENTER" maxWidth="Infinity">
            <Button text="Πίσω" onAction="#handleBack"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button fx:id="selectOfferButton" text="Επιλογή &amp; Προβολή" onAction="#handleSelectOffer"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #1ea1e2; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</VBox>