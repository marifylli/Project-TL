<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.unipath.ui.UC8.HelpServicesScreen"
      alignment="CENTER"
      spacing="20"
      styleClass="root-pane"
      stylesheets="@../../css/styles.css">

    <VBox alignment="CENTER" spacing="10" styleClass="login-card" maxWidth="500" style="-fx-padding: 30;">
        <Label text="UniPath - Παροχές Ακαδημαϊκής Βοήθειας" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1ea1e2;"/>
        <Label fx:id="mentorLabel" text="Mentor: " style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Label fx:id="typeLabel" text="Τύπος Βοήθειας: " style="-fx-font-size: 14px; -fx-text-fill: gray;"/>
        <Region minHeight="15"/>

        <VBox alignment="CENTER" spacing="15" maxWidth="Infinity" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-background-radius: 5; -fx-border-color: #dee2e6;">
            <Label fx:id="detailsLabel" text="Διαθέσιμο Υλικό:" style="-fx-font-weight: bold;"/>
            <Button fx:id="actionButton" text="Έναρξη Λήψης / Σύνδεσης" onAction="#handleExecuteAction"
                    maxWidth="250" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </VBox>

        <Region minHeight="25"/>

        <HBox spacing="15" alignment="CENTER" maxWidth="Infinity">
            <Button text="Πίσω στις Προσφορές" onAction="#handleBack"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button text="Ολοκλήρωση" onAction="#handleFinalize"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #1ea1e2; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</VBox>
