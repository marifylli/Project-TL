<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unipath.ui.UC11.ThesisDetailsScreen">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1e3a8a; -fx-padding: 20;">
            <children>
                <Label text="Στοιχεία Θέματος Διπλωματικής Εργασίας" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 20;">
            <content>
                <VBox spacing="25.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                    <children>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Τίτλος Θέματος" textFill="#64748b" />
                                <Label fx:id="titleLabel" text="Φορτώνει τίτλος..." textFill="#1e40af" wrapText="true">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Περιγραφή &amp; Στόχοι" textFill="#64748b" />
                                <Label fx:id="descriptionLabel" text="Φορτώνει περιγραφή..." wrapText="true">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Προαπαιτούμενα Μαθήματα" textFill="#64748b" />
                                <Label fx:id="prerequisitesLabel" text="Φορτώνει προαπαιτούμενα..." wrapText="true">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <HBox spacing="50.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Απαιτούμενα ECTS" textFill="#64748b" />
                                        <Label fx:id="ectsLabel" text="-" textFill="#b91c1c">
                                            <font>
                                                <Font name="System Bold" size="16.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Επιθυμητές Δεξιότητες / Τεχνολογίες" textFill="#64748b" />
                                        <Label fx:id="skillsLabel" text="Φορτώνει δεξιότητες..." wrapText="true">
                                            <font>
                                                <Font size="15.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
                            <children>
                                <Button mnemonicParsing="false" onAction="#selectExpressInterest" prefHeight="50.0" prefWidth="260.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="📝 Εκδήλωση Ενδιαφέροντος">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>