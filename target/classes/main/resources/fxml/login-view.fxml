<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.unipath.login.LoginController"
           styleClass="root-pane">

    <VBox alignment="CENTER" maxWidth="380" spacing="0" styleClass="login-card">

        <!-- TOP: μπλε header με logo -->
        <VBox styleClass="card-top" spacing="8">
            <StackPane styleClass="logo-circle" maxWidth="64">
                <Label text="CEID" styleClass="logo-label"/>
            </StackPane>
            <Label text="Σύστημα Ακαδημαϊκής Πορείας" styleClass="app-name"/>
            <Label text="Τμήμα Μηχ. Η/Υ &amp; Πληροφορικής — Παν. Πατρών"
                   styleClass="uni-name"/>
        </VBox>

        <!-- BODY -->
        <VBox styleClass="card-body" spacing="0">

            <!-- Step dots -->
            <HBox alignment="CENTER" spacing="8" styleClass="step-dots-container">
                <Circle fx:id="dot1" radius="5" styleClass="dot-active"/>
                <Circle fx:id="dot2" radius="5" styleClass="dot-inactive"/>
                <Circle fx:id="dot3" radius="5" styleClass="dot-inactive"/>
            </HBox>

            <!-- SCREEN 1: Email -->
            <VBox fx:id="screenEmail" spacing="10">
                <Label text="Ακαδημαϊκό email" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="st12345@ceid.upatras.gr"
                           styleClass="text-field-custom"
                           maxWidth="Infinity"
                           onKeyReleased="#onEmailTyped"/>
                <VBox styleClass="info-box" spacing="2">
                    <Label text="Θα σας αποσταλεί ένας 6-ψήφιος κωδικός επαλήθευσης."
                           styleClass="info-text" wrapText="true"/>
                    <Label text="Ισχύει για 5 λεπτά."
                           styleClass="info-text"/>
                </VBox>
                <VBox spacing="4" style="-fx-padding: 8 0 0 0;">
                    <Button fx:id="sendOtpButton"
                            text="Αποστολή κωδικού →"
                            styleClass="btn-primary"
                            maxWidth="Infinity"
                            onAction="#onSendOtp"/>
                    <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
                </VBox>
            </VBox>

            <!-- SCREEN 2: OTP -->
            <VBox fx:id="screenOtp" spacing="10" managed="false" visible="false">
                <Label text="Εισάγετε τον κωδικό" styleClass="app-name"
                       style="-fx-text-fill: #1a3a6b; -fx-font-size: 16px;"/>
                <Label fx:id="sentToLabel" text="" styleClass="hint-label" wrapText="true"/>
                <HBox alignment="CENTER" spacing="8" style="-fx-padding: 4 0 4 0;">
                    <TextField fx:id="otp1" maxWidth="46" styleClass="otp-box" onKeyReleased="#onOtpKey"/>
                    <TextField fx:id="otp2" maxWidth="46" styleClass="otp-box" onKeyReleased="#onOtpKey"/>
                    <TextField fx:id="otp3" maxWidth="46" styleClass="otp-box" onKeyReleased="#onOtpKey"/>
                    <TextField fx:id="otp4" maxWidth="46" styleClass="otp-box" onKeyReleased="#onOtpKey"/>
                    <TextField fx:id="otp5" maxWidth="46" styleClass="otp-box" onKeyReleased="#onOtpKey"/>
                    <TextField fx:id="otp6" maxWidth="46" styleClass="otp-box" onKeyReleased="#onOtpKey"/>
                </HBox>
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Δεν λάβατε κωδικό;" styleClass="hint-label"/>
                    <Hyperlink fx:id="resendLink" text="Αποστολή εκ νέου" onAction="#onResend"
                               style="-fx-text-fill: #1a3a6b;"/>
                    <Label fx:id="timerLabel" text="(04:59)" styleClass="hint-label"/>
                </HBox>
                <Button text="Επαλήθευση →" styleClass="btn-primary"
                        maxWidth="Infinity" onAction="#onVerifyOtp"/>
                <Button text="← Επιστροφή" styleClass="btn-secondary"
                        maxWidth="Infinity" onAction="#onBack"/>
                <Label fx:id="otpErrorLabel" styleClass="error-label" text="" wrapText="true"/>
            </VBox>

            <!-- SCREEN 3: Success -->
            <VBox fx:id="screenSuccess" spacing="12" managed="false" visible="false"
                  alignment="CENTER">
                <Label text="Επαλήθευση επιτυχής!" styleClass="success-title"/>
                <Label fx:id="roleLabel" text="" styleClass="role-badge"/>
                <Label fx:id="redirectLabel" text="" styleClass="hint-label" wrapText="true"/>
                <Button text="Είσοδος →" styleClass="btn-primary"
                        maxWidth="Infinity" onAction="#onEnterDashboard"/>
            </VBox>

        </VBox>

        <!-- FOOTER -->
        <HBox styleClass="card-footer" alignment="CENTER">
            <Label text="Πανεπιστήμιο Πατρών — 2026" styleClass="footer-label"/>
        </HBox>

    </VBox>
</StackPane>